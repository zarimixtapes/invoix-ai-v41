# Database (SQLite by default, swap to a Postgres URL for production)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic API key for AI-assisted invoice drafting & reminders.
# If unset, the app falls back to a template-based mock so it still works.
ANTHROPIC_API_KEY=""

# Stripe (subscription billing). If unset, billing routes return a clear error.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_PRO=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
